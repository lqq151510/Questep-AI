<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.interview.infrastructure.persistence.mapper.WrongBookMapper">
    <resultMap id="wrongBookMap" type="com.interview.domain.model.WrongBook">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="question_id" javaType="java.lang.Long"/>
            <arg column="first_wrong_at" javaType="java.time.LocalDateTime"/>
            <arg column="last_wrong_at" javaType="java.time.LocalDateTime"/>
            <arg column="wrong_count" javaType="java.lang.Integer"/>
            <arg column="mastery_status" javaType="java.lang.String"/>
            <arg column="last_review_at" javaType="java.time.LocalDateTime"/>
            <arg column="notes" javaType="java.lang.String"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <resultMap id="wrongBookPOMap" type="com.interview.infrastructure.persistence.entity.WrongBookPO">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="questionId" column="question_id"/>
        <result property="firstWrongAt" column="first_wrong_at"/>
        <result property="lastWrongAt" column="last_wrong_at"/>
        <result property="wrongCount" column="wrong_count"/>
        <result property="masteryStatus" column="mastery_status"/>
        <result property="lastReviewAt" column="last_review_at"/>
        <result property="notes" column="notes"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="wrongBookColumns">
        id,user_id,question_id,first_wrong_at,last_wrong_at,wrong_count,mastery_status,last_review_at,notes,created_at,updated_at
    </sql>

    <insert id="insert" parameterType="com.interview.infrastructure.persistence.entity.WrongBookPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO wrong_book (user_id, question_id, wrong_count, mastery_status)
        VALUES (#{userId}, #{questionId}, 1, 'UNMASTERED')
    </insert>

    <select id="selectById" resultMap="wrongBookMap">
        SELECT <include refid="wrongBookColumns"/>
        FROM wrong_book
        WHERE id = #{id}
    </select>

    <select id="selectByUserIdAndQuestionId" resultMap="wrongBookMap">
        SELECT <include refid="wrongBookColumns"/>
        FROM wrong_book
        WHERE user_id = #{userId} AND question_id = #{questionId}
    </select>

    <select id="selectByUserId" resultMap="wrongBookMap">
        SELECT <include refid="wrongBookColumns"/>
        FROM wrong_book
        WHERE user_id = #{userId}
        ORDER BY last_wrong_at DESC
    </select>

    <select id="selectByUserIdAndMasteryStatus" resultMap="wrongBookMap">
        SELECT <include refid="wrongBookColumns"/>
        FROM wrong_book
        WHERE user_id = #{userId} AND mastery_status = #{masteryStatus}
        ORDER BY last_wrong_at DESC
    </select>

    <update id="updateMasteryStatus">
        UPDATE wrong_book
        SET mastery_status = #{masteryStatus},
            last_review_at = CURRENT_TIMESTAMP,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <update id="incrementWrongCount">
        UPDATE wrong_book
        SET wrong_count = wrong_count + 1,
            last_wrong_at = CURRENT_TIMESTAMP,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <update id="updateNotes">
        UPDATE wrong_book
        SET notes = #{notes},
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM wrong_book WHERE id = #{id}
    </delete>
</mapper>
