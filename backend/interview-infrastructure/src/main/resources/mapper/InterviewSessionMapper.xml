<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.interview.infrastructure.persistence.mapper.InterviewSessionMapper">
    <resultMap id="sessionMap" type="com.interview.domain.model.InterviewSession">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="position" javaType="java.lang.String"/>
            <arg column="difficulty" javaType="java.lang.Integer"/>
            <arg column="status" javaType="java.lang.String"/>
            <arg column="context_snapshot" javaType="java.lang.String"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <resultMap id="sessionPOMap" type="com.interview.infrastructure.persistence.entity.InterviewSessionPO">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="position" column="position"/>
        <result property="difficulty" column="difficulty"/>
        <result property="status" column="status"/>
        <result property="contextSnapshot" column="context_snapshot"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="sessionColumns">
        id,user_id,position,difficulty,status,context_snapshot,created_at,updated_at
    </sql>

    <sql id="sessionInsertColumns">
        <trim suffixOverrides=",">
            user_id,
            <if test="position != null">position,</if>
            <if test="difficulty != null">difficulty,</if>
            <if test="status != null">status,</if>
            <if test="contextSnapshot != null">context_snapshot,</if>
        </trim>
    </sql>

    <sql id="sessionInsertValues">
        <trim suffixOverrides=",">
            #{userId},
            <if test="position != null">#{position},</if>
            <if test="difficulty != null">#{difficulty},</if>
            <if test="status != null">#{status},</if>
            <if test="contextSnapshot != null">#{contextSnapshot},</if>
        </trim>
    </sql>

    <insert id="insert" parameterType="com.interview.infrastructure.persistence.entity.InterviewSessionPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO interview_session (
            <include refid="sessionInsertColumns"/>
        )
        VALUES (
            <include refid="sessionInsertValues"/>
        )
    </insert>

    <update id="updateById" parameterType="com.interview.infrastructure.persistence.entity.InterviewSessionPO">
        UPDATE interview_session
        <set>
            <if test="position != null">position = #{position},</if>
            <if test="difficulty != null">difficulty = #{difficulty},</if>
            <if test="status != null">status = #{status},</if>
            <if test="contextSnapshot != null">context_snapshot = #{contextSnapshot},</if>
            updated_at = CURRENT_TIMESTAMP
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateStatusAndSnapshot">
        UPDATE interview_session
        SET status = #{status},
            context_snapshot = #{contextSnapshot},
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="sessionMap">
        SELECT <include refid="sessionColumns"/>
        FROM interview_session
        WHERE id = #{id}
    </select>

    <select id="selectActiveByUserId" resultMap="sessionMap">
        SELECT <include refid="sessionColumns"/>
        FROM interview_session
        WHERE user_id = #{userId}
          AND status = 'ACTIVE'
        ORDER BY id DESC
        LIMIT 1
    </select>
</mapper>
