<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.interview.infrastructure.persistence.mapper.AsyncTaskRecordMapper">
    <resultMap id="taskMap" type="com.interview.domain.model.AsyncTaskRecord">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="task_no" javaType="java.lang.String"/>
            <arg column="task_type" javaType="java.lang.String"/>
            <arg column="biz_id" javaType="java.lang.Long"/>
            <arg column="status" javaType="java.lang.String"/>
            <arg column="progress" javaType="java.lang.Integer"/>
            <arg column="error_msg" javaType="java.lang.String"/>
            <arg column="created_by" javaType="java.lang.Long"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>
    <insert id="insert" parameterType="com.interview.infrastructure.persistence.entity.AsyncTaskRecordPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO async_task_records (task_no,task_type,biz_id,status,progress,created_by)
        VALUES (#{taskNo},#{taskType},#{bizId},#{status},#{progress},#{createdBy})
    </insert>
    <select id="selectById" resultMap="taskMap">SELECT id,task_no,task_type,biz_id,status,progress,error_msg,created_by,created_at,updated_at FROM async_task_records WHERE id=#{id}</select>
    <select id="selectByTaskNo" resultMap="taskMap">SELECT id,task_no,task_type,biz_id,status,progress,error_msg,created_by,created_at,updated_at FROM async_task_records WHERE task_no=#{taskNo}</select>
</mapper>
