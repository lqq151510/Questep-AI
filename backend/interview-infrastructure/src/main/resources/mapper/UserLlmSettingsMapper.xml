<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.interview.infrastructure.persistence.mapper.UserLlmSettingsMapper">
    <resultMap id="userLlmSettingsMap" type="com.interview.domain.model.UserLlmSettings">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="provider_name" javaType="java.lang.String"/>
            <arg column="model_name" javaType="java.lang.String"/>
            <arg column="base_url" javaType="java.lang.String"/>
            <arg column="api_key" javaType="java.lang.String"/>
            <arg column="enabled" javaType="java.lang.Integer"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="selectByUserId" resultMap="userLlmSettingsMap">
        SELECT id, user_id, provider_name, model_name, base_url, api_key, enabled, created_at, updated_at
        FROM user_llm_settings
        WHERE user_id = #{userId}
        LIMIT 1
    </select>

    <insert id="upsert" parameterType="com.interview.infrastructure.persistence.entity.UserLlmSettingsPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_llm_settings (
            user_id,
            provider_name,
            model_name,
            base_url,
            api_key,
            enabled
        ) VALUES (
            #{userId},
            #{providerName},
            #{modelName},
            #{baseUrl},
            #{apiKey},
            #{enabled}
        )
        ON DUPLICATE KEY UPDATE
            provider_name = VALUES(provider_name),
            model_name = VALUES(model_name),
            base_url = VALUES(base_url),
            api_key = VALUES(api_key),
            enabled = VALUES(enabled),
            updated_at = CURRENT_TIMESTAMP
    </insert>
</mapper>
