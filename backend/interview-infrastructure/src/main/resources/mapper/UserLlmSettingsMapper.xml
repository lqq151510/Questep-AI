<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.interview.infrastructure.persistence.mapper.UserLlmSettingsMapper">
    <resultMap id="userLlmSettingsMap" type="com.interview.infrastructure.persistence.entity.UserLlmSettingsPO">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="providerName" column="provider_name"/>
        <result property="modelName" column="model_name"/>
        <result property="baseUrl" column="base_url"/>
        <result property="apiKey" column="api_key"/>
        <result property="enabled" column="enabled"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectByUserId" resultMap="userLlmSettingsMap">
        SELECT id, user_id, provider_name, model_name, base_url, api_key, enabled, created_at, updated_at
        FROM user_llm_settings
        WHERE user_id = #{userId}
        LIMIT 1
    </select>

    <insert id="upsert" parameterType="com.interview.infrastructure.persistence.entity.UserLlmSettingsPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_llm_settings (
            user_id,
            provider_name,
            model_name,
            base_url,
            api_key,
            enabled
        ) VALUES (
            #{userId},
            #{providerName},
            #{modelName},
            #{baseUrl},
            #{apiKey},
            #{enabled}
        )
        ON DUPLICATE KEY UPDATE
            provider_name = VALUES(provider_name),
            model_name = VALUES(model_name),
            base_url = VALUES(base_url),
            api_key = VALUES(api_key),
            enabled = VALUES(enabled),
            updated_at = CURRENT_TIMESTAMP
    </insert>
</mapper>
