<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.interview.infrastructure.persistence.mapper.QuestionMapper">
    <resultMap id="questionMap" type="com.interview.domain.model.Question">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="material_id" javaType="java.lang.Long"/>
            <arg column="creator_user_id" javaType="java.lang.Long"/>
            <arg column="question_type" javaType="java.lang.String"/>
            <arg column="stem_text" javaType="java.lang.String"/>
            <arg column="reference_answer" javaType="java.lang.String"/>
            <arg column="analysis_text" javaType="java.lang.String"/>
            <arg column="difficulty" javaType="java.lang.Integer"/>
            <arg column="source_type" javaType="java.lang.String"/>
            <arg column="model_name" javaType="java.lang.String"/>
            <arg column="source_url" javaType="java.lang.String"/>
            <arg column="source_version" javaType="java.lang.String"/>
            <arg column="last_verified_at" javaType="java.time.LocalDateTime"/>
            <arg column="confidence_score" javaType="java.math.BigDecimal"/>
            <arg column="expires_at" javaType="java.time.LocalDateTime"/>
            <arg column="review_status" javaType="java.lang.String"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <resultMap id="questionPOMap" type="com.interview.infrastructure.persistence.entity.QuestionPO">
        <id property="id" column="id"/>
        <result property="materialId" column="material_id"/>
        <result property="creatorUserId" column="creator_user_id"/>
        <result property="questionType" column="question_type"/>
        <result property="stemText" column="stem_text"/>
        <result property="optionsJson" column="options_json"/>
        <result property="referenceAnswer" column="reference_answer"/>
        <result property="analysisText" column="analysis_text"/>
        <result property="difficulty" column="difficulty"/>
        <result property="sourceType" column="source_type"/>
        <result property="modelName" column="model_name"/>
        <result property="sourceUrl" column="source_url"/>
        <result property="sourceVersion" column="source_version"/>
        <result property="lastVerifiedAt" column="last_verified_at"/>
        <result property="confidenceScore" column="confidence_score"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="reviewStatus" column="review_status"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="questionColumns">
        id,material_id,creator_user_id,question_type,stem_text,options_json,reference_answer,analysis_text,difficulty,source_type,model_name,source_url,source_version,last_verified_at,confidence_score,expires_at,review_status,status,created_at,updated_at
    </sql>

    <sql id="questionInsertColumns">
        <trim suffixOverrides=",">
            <if test="materialId != null">material_id,</if>
            <if test="creatorUserId != null">creator_user_id,</if>
            question_type,
            stem_text,
            <if test="optionsJson != null">options_json,</if>
            <if test="referenceAnswer != null">reference_answer,</if>
            <if test="analysisText != null">analysis_text,</if>
            <if test="difficulty != null">difficulty,</if>
            <if test="sourceType != null">source_type,</if>
            <if test="modelName != null">model_name,</if>
            <if test="sourceUrl != null">source_url,</if>
            <if test="sourceVersion != null">source_version,</if>
            <if test="lastVerifiedAt != null">last_verified_at,</if>
            <if test="confidenceScore != null">confidence_score,</if>
            <if test="expiresAt != null">expires_at,</if>
            <if test="reviewStatus != null">review_status,</if>
            <if test="status != null">status,</if>
        </trim>
    </sql>

    <sql id="questionInsertValues">
        <trim suffixOverrides=",">
            <if test="materialId != null">#{materialId},</if>
            <if test="creatorUserId != null">#{creatorUserId},</if>
            #{questionType},
            #{stemText},
            <if test="optionsJson != null">#{optionsJson},</if>
            <if test="referenceAnswer != null">#{referenceAnswer},</if>
            <if test="analysisText != null">#{analysisText},</if>
            <if test="difficulty != null">#{difficulty},</if>
            <if test="sourceType != null">#{sourceType},</if>
            <if test="modelName != null">#{modelName},</if>
            <if test="sourceUrl != null">#{sourceUrl},</if>
            <if test="sourceVersion != null">#{sourceVersion},</if>
            <if test="lastVerifiedAt != null">#{lastVerifiedAt},</if>
            <if test="confidenceScore != null">#{confidenceScore},</if>
            <if test="expiresAt != null">#{expiresAt},</if>
            <if test="reviewStatus != null">#{reviewStatus},</if>
            <if test="status != null">#{status},</if>
        </trim>
    </sql>

    <insert id="insert" parameterType="com.interview.infrastructure.persistence.entity.QuestionPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO questions (
            <include refid="questionInsertColumns"/>
        )
        VALUES (
            <include refid="questionInsertValues"/>
        )
    </insert>

    <update id="updateById" parameterType="com.interview.infrastructure.persistence.entity.QuestionPO">
        UPDATE questions
        <set>
            <if test="materialId != null">material_id = #{materialId},</if>
            <if test="creatorUserId != null">creator_user_id = #{creatorUserId},</if>
            <if test="questionType != null">question_type = #{questionType},</if>
            <if test="stemText != null">stem_text = #{stemText},</if>
            <if test="optionsJson != null">options_json = #{optionsJson},</if>
            <if test="referenceAnswer != null">reference_answer = #{referenceAnswer},</if>
            <if test="analysisText != null">analysis_text = #{analysisText},</if>
            <if test="difficulty != null">difficulty = #{difficulty},</if>
            <if test="sourceType != null">source_type = #{sourceType},</if>
            <if test="modelName != null">model_name = #{modelName},</if>
            <if test="sourceUrl != null">source_url = #{sourceUrl},</if>
            <if test="sourceVersion != null">source_version = #{sourceVersion},</if>
            <if test="lastVerifiedAt != null">last_verified_at = #{lastVerifiedAt},</if>
            <if test="confidenceScore != null">confidence_score = #{confidenceScore},</if>
            <if test="expiresAt != null">expires_at = #{expiresAt},</if>
            <if test="reviewStatus != null">review_status = #{reviewStatus},</if>
            <if test="status != null">status = #{status},</if>
            updated_at = CURRENT_TIMESTAMP
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="questionMap">
        SELECT <include refid="questionColumns"/>
        FROM questions
        WHERE id = #{id}
    </select>

    <select id="selectRecentByUser" resultMap="questionMap">
        SELECT <include refid="questionColumns"/>
        FROM questions
        WHERE creator_user_id = #{userId}
          AND status = 1
          AND review_status = 'APPROVED'
          AND (expires_at IS NULL OR expires_at > CURRENT_TIMESTAMP)
          AND confidence_score >= 0.700
        ORDER BY id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countFreshApprovedByUser" resultType="int">
        SELECT COUNT(1)
        FROM questions
        WHERE creator_user_id = #{userId}
          AND status = 1
          AND review_status = 'APPROVED'
          AND confidence_score >= 0.700
          AND (expires_at IS NULL OR expires_at > #{now})
    </select>

    <select id="selectByCondition" resultMap="questionMap">
        SELECT <include refid="questionColumns"/>
        FROM questions
        <where>
            <if test="materialId != null">AND material_id = #{materialId}</if>
            <if test="creatorUserId != null">AND creator_user_id = #{creatorUserId}</if>
            <if test="questionType != null and questionType != ''">AND question_type = #{questionType}</if>
            <if test="difficulty != null">AND difficulty = #{difficulty}</if>
            <if test="sourceType != null and sourceType != ''">AND source_type = #{sourceType}</if>
            <if test="modelName != null and modelName != ''">AND model_name = #{modelName}</if>
            <if test="status != null">AND status = #{status}</if>
        </where>
        ORDER BY id DESC
        <if test="limit != null">LIMIT #{limit}</if>
    </select>

    <select id="selectByIds" resultMap="questionMap">
        SELECT <include refid="questionColumns"/>
        FROM questions
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <delete id="deleteById" parameterType="long">
        DELETE FROM questions WHERE id = #{id}
    </delete>

    <update id="markExpiredForReview">
        UPDATE questions
        SET review_status = #{reviewStatus},
            last_verified_at = #{reviewedAt},
            updated_at = CURRENT_TIMESTAMP
        WHERE expires_at IS NOT NULL
          AND expires_at &lt;= #{reviewedAt}
          AND (review_status IS NULL OR review_status != #{reviewStatus})
    </update>

    <select id="selectPendingRefreshCandidates" resultMap="questionMap">
        SELECT <include refid="questionColumns"/>
        FROM questions
        WHERE status = 1
          AND review_status = #{reviewStatus}
          AND material_id IS NOT NULL
          AND creator_user_id IS NOT NULL
        ORDER BY expires_at ASC, id ASC
        LIMIT #{limit}
    </select>

    <update id="archiveQuestion">
        UPDATE questions
        SET status = 0,
            updated_at = CURRENT_TIMESTAMP,
            last_verified_at = #{archivedAt}
        WHERE id = #{questionId}
    </update>
</mapper>
